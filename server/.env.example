PORT=3000
NODE_ENV=development
CORS_ORIGIN=https://nordinesahel-portfolio.fr
SESSION_SECRET=replace-with-64-plus-random-characters
SESSION_COOKIE_SECURE=true
ADMIN_USERNAME=replace-admin-username
ADMIN_PASSWORD=replace-with-strong-password
DB_PATH=./storage/data.sqlite
SESSIONS_DB=./storage/sessions.sqlite
LOG_DIR=./logs
PUBLIC_ORIGIN=https://nordinesahel-portfolio.fr
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=365

# Injectez ces variables au runtime (environnement OS, CI/CD ou Docker secrets)
CONTACT_TO=
CONTACT_FROM=
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
FORMSUBMIT_ENABLED=true
FORMSUBMIT_RECIPIENT=
FORMSUBMIT_ENDPOINT=

# Optionnel: utiliser des fichiers Docker secrets
# SMTP_USER_FILE=/run/secrets/smtp_user
# SMTP_PASS_FILE=/run/secrets/smtp_pass
